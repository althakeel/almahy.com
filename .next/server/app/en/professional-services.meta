{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/professional-services/layout,_N_T_/[locale]/professional-services/page,_N_T_/en/professional-services"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/professional-services/__PAGE__",
    "/$d$locale/professional-services",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}