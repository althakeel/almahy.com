16:["$","article","Criminal",{"className":"rounded-2xl border border-white/10 bg-gradient-to-br from-white/[0.04] to-white/[0.02] overflow-hidden","children":["$","div",null,{"className":"grid md:grid-cols-5 ","children":[["$","div",null,{"className":"relative md:col-span-2 h-56 md:h-full min-h-56","children":[["$","$L10",null,{"src":"https://images.unsplash.com/photo-1505664194779-8beaceb93744?w=1200&h=700&fit=crop","alt":"Criminal legal services","fill":true,"className":"object-cover"}],["$","div",null,{"className":"absolute inset-0 bg-gradient-to-t md:bg-gradient-to-r from-black/50 to-transparent"}]]}],["$","div",null,{"className":"md:col-span-3 p-6 md:p-8","children":[["$","div",null,{"className":"flex items-center gap-3 mb-4","children":[["$","span",null,{"className":"inline-flex h-8 w-8 items-center justify-center rounded-full border border-white/20 text-sm text-slate-200","children":5}],["$","h2",null,{"className":"text-2xl font-semibold","style":{"color":"#F8E48B"},"children":"Criminal"}]]}],["$","div",null,{"className":"space-y-3","children":[["$","p","Criminal allegations in the UAE can have serious legal and reputational impact. Our criminal law team provides strategic defense for individuals and companies in cases including fraud, embezzlement, cybercrime, drug offenses, defamation, breach of trust, and violent offenses.",{"className":"text-slate-200 leading-relaxed","children":"Criminal allegations in the UAE can have serious legal and reputational impact. Our criminal law team provides strategic defense for individuals and companies in cases including fraud, embezzlement, cybercrime, drug offenses, defamation, breach of trust, and violent offenses."}],["$","p","We represent clients from police investigations and prosecution through trial and appeal, and also assist with bail applications and criminal record clearance under UAE Penal Code and Criminal Procedure Law.",{"className":"text-slate-200 leading-relaxed","children":"We represent clients from police investigations and prosecution through trial and appeal, and also assist with bail applications and criminal record clearance under UAE Penal Code and Criminal Procedure Law."}]]}]]}]]}]}]
