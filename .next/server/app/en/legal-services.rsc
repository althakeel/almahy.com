12:["$","div",null,{"className":"md:col-span-3 p-6 md:p-8","children":[["$","div",null,{"className":"flex items-center gap-3 mb-4","children":[["$","span",null,{"className":"inline-flex h-8 w-8 items-center justify-center rounded-full border border-white/20 text-sm text-slate-200","children":1}],["$","h2",null,{"className":"text-2xl font-semibold","style":{"color":"#F8E48B"},"children":"Arbitration, Banking & Tax"}]]}],["$","div",null,{"className":"space-y-3","children":[["$","p","Arbitration is a preferred method of dispute resolution in the UAE, especially in commercial and cross-border matters. Our firm represents clients in proceedings governed by local and international rules, including DIAC, DIFC-LCIA, ICC, and UNCITRAL.",{"className":"text-slate-200 leading-relaxed","children":"Arbitration is a preferred method of dispute resolution in the UAE, especially in commercial and cross-border matters. Our firm represents clients in proceedings governed by local and international rules, including DIAC, DIFC-LCIA, ICC, and UNCITRAL."}],["$","p","We assist with arbitration clauses, statements of claim and defense, arbitrator appointments, and enforcement or challenge of arbitral awards before UAE courts. Our lawyers are experienced in construction, banking, real estate, energy, and shareholder disputes.",{"className":"text-slate-200 leading-relaxed","children":"We assist with arbitration clauses, statements of claim and defense, arbitrator appointments, and enforcement or challenge of arbitral awards before UAE courts. Our lawyers are experienced in construction, banking, real estate, energy, and shareholder disputes."}],["$","p","Our banking and tax practice supports financial institutions, lenders, borrowers, fintech startups, and corporates with loan agreements, guarantees, Islamic finance structures (Murabaha, Ijara, Sukuk), syndicated lending, and cross-border finance. We also advise on UAE corporate tax planning, international tax compliance, economic substance regulations, and VAT strategy.",{"className":"text-slate-200 leading-relaxed","children":"Our banking and tax practice supports financial institutions, lenders, borrowers, fintech startups, and corporates with loan agreements, guarantees, Islamic finance structures (Murabaha, Ijara, Sukuk), syndicated lending, and cross-border finance. We also advise on UAE corporate tax planning, international tax compliance, economic substance regulations, and VAT strategy."}]]}]]}]
13:["$","article","Bankruptcy & Insolvency",{"className":"rounded-2xl border border-white/10 bg-gradient-to-br from-white/[0.04] to-white/[0.02] overflow-hidden","children":["$","div",null,{"className":"grid md:grid-cols-5 md:[&>*:first-child]:order-2","children":[["$","div",null,{"className":"relative md:col-span-2 h-56 md:h-full min-h-56","children":[["$","$L10",null,{"src":"https://images.unsplash.com/photo-1554224155-8d04cb21cd6c?w=1200&h=700&fit=crop","alt":"Bankruptcy & Insolvency legal services","fill":true,"className":"object-cover"}],["$","div",null,{"className":"absolute inset-0 bg-gradient-to-t md:bg-gradient-to-r from-black/50 to-transparent"}]]}],["$","div",null,{"className":"md:col-span-3 p-6 md:p-8","children":[["$","div",null,{"className":"flex items-center gap-3 mb-4","children":[["$","span",null,{"className":"inline-flex h-8 w-8 items-center justify-center rounded-full border border-white/20 text-sm text-slate-200","children":2}],["$","h2",null,{"className":"text-2xl font-semibold","style":{"color":"#F8E48B"},"children":"Bankruptcy & Insolvency"}]]}],["$","div",null,{"className":"space-y-3","children":[["$","p","Facing financial difficulties can be challenging for both individuals and businesses. We guide clients through insolvency and bankruptcy procedures under UAE Federal Decree-Law No. (9) of 2016 and subsequent updates.",{"className":"text-slate-200 leading-relaxed","children":"Facing financial difficulties can be challenging for both individuals and businesses. We guide clients through insolvency and bankruptcy procedures under UAE Federal Decree-Law No. (9) of 2016 and subsequent updates."}],["$","p","For companies, we provide restructuring strategies, debt settlement support, and court-supervised liquidation assistance. For creditors, we pursue claims, represent interests in committees, and safeguard asset recovery with practical, outcome-focused legal support.",{"className":"text-slate-200 leading-relaxed","children":"For companies, we provide restructuring strategies, debt settlement support, and court-supervised liquidation assistance. For creditors, we pursue claims, represent interests in committees, and safeguard asset recovery with practical, outcome-focused legal support."}]]}]]}]]}]}]
