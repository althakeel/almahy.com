{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/tax-services/layout,_N_T_/[locale]/tax-services/page,_N_T_/ar/tax-services"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/tax-services/__PAGE__",
    "/$d$locale/tax-services",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}