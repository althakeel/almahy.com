{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/second-passport/layout,_N_T_/[locale]/second-passport/page,_N_T_/ar/second-passport"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/second-passport/__PAGE__",
    "/$d$locale/second-passport",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}